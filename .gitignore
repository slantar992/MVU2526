# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
/MVU2526/.utmp/
/MVU2526/[Ll]ibrary/
/MVU2526/[Tt]emp/
/MVU2526/[Oo]bj/
/MVU2526/[Bb]uild/
/MVU2526/[Bb]uilds/
/MVU2526/[Ll]ogs/
/MVU2526/[Uu]ser[Ss]ettings/
*.log

# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
*.blend1
*.blend1.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/MVU2526/[Mm]emoryCaptures/

# Recordings can get excessive in size
/MVU2526/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /MVU2526/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/MVU2526/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
*.DotSettings.user

# Visual Studio cache directory
/MVU2526/.vs/

# Gradle cache directory
/MVU2526/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
/MVU2526/ExportedObj/
/MVU2526/.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Mono auto generated files
mono_crash.*

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics generated file
/MVU2526/crashlytics-build.properties

# TestRunner generated files
/MVU2526/InitTestScene*.unity*

# Addressables default ignores, before user customizations
/MVU2526/ServerData
/MVU2526/[Aa]ssets/StreamingAssets/aa*
/MVU2526/[Aa]ssets/AddressableAssetsData/link.xml*
/MVU2526/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /MVU2526/Assets/AddressableAssetsData/OSX/addressables_content_state.bin
/MVU2526/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
/MVU2526/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/MVU2526/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/MVU2526/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/MVU2526/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
/MVU2526/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
